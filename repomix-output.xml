                <input id="entryProductName" type="text" required class="w-full rounded-xl border-slate-200 focus:ring-primary" placeholder="Örn: Çelik Mil">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold uppercase mb-1">Miktar</label>
                    <input id="entryQuantity" type="number" min="1" required class="w-full rounded-xl border-slate-200" placeholder="0">
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-1">Birim</label>
                    <select id="entryUnit" class="w-full rounded-xl border-slate-200">
                        <option>Adet</option>
                        <option>Kg</option>
                        <option>Metre</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold uppercase mb-1">Departman</label>
                    <select id="entryDepartment" class="w-full rounded-xl border-slate-200">
                        <option>Montaj</option>
                        <option>Elektrik</option>
                        <option>Kalite Kontrol</option>
                        <option>Bakım</option>
                        <option>Kesim Hattı</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-1">Tarih</label>
                    <input id="entryDate" type="date" required class="w-full rounded-xl border-slate-200">
                </div>
            </div>
            <div class="flex gap-3 mt-8">
                <button type="button" onclick="toggleModal('entryModal')" class="flex-1 py-3 font-bold text-slate-500">İptal</button>
                <button type="submit" class="flex-1 py-3 bg-primary text-white rounded-xl font-bold shadow-lg shadow-primary/20">Kaydet</button>
            </div>
        </form>
    </div>
</div>
<!-- Barkod ve QR Kod Okutma Modalı -->
<div id="scannerModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/90 p-4">
    <div class="bg-white w-full max-w-lg rounded-3xl overflow-hidden shadow-2xl">
        <div class="p-6 flex justify-between items-center border-b">
            <h3 class="font-headline font-bold">Barkod Tara</h3>
            <button onclick="stopCamera()" class="material-symbols-outlined text-slate-400">close</button>
        </div>
        <div id="video-container" class="bg-black aspect-video relative">
            <video id="preview"></video>
            <div id="scanFrame" class="absolute inset-0 border-2 border-primary/50 m-12 rounded-lg pointer-events-none animate-pulse transition-colors duration-300"></div>
            <div id="scanStatusText" class="absolute left-4 right-4 bottom-4 text-center bg-black/60 text-white text-xs font-semibold py-2 px-3 rounded-lg">
                Geçerli barkod veya QR kod okutunuz
            </div>
        </div>
        <div class="p-6 text-center">
            <p class="text-sm text-slate-500">Kamerayı barkoda yaklaştırın</p>
            <div class="mt-4 pt-4 border-t border-slate-100 space-y-2">
                <p class="text-xs text-slate-400">Kod okunmuyorsa manuel girin</p>
                <div class="flex gap-2">
                    <input id="manualCodeInput" type="text" class="flex-1 rounded-xl border-slate-200 text-sm" placeholder="Malzeme kodunu yazın">
                    <button id="manualCodeApplyBtn" type="button" class="px-4 py-2 bg-primary text-white rounded-xl text-sm font-bold">Uygula</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/@zxing/library@latest"></script>
<script src="https://unpkg.com/jsqr@1.4.0/dist/jsQR.js"></script>
<script>
    // Modal Yönetimi
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
        if(id === 'scannerModal' && !modal.classList.contains('hidden')) {
            startCamera();
        }
    }

    // Helper to log system events
    function logSystemEvent(user, action, location, status) {
        const logs = JSON.parse(localStorage.getItem('systemLogs')) || [];
        logs.unshift({
            user: user,
            action: action,
            location: location,
            time: new Date().toISOString(),
            status: status
        });
        localStorage.setItem('systemLogs', JSON.stringify(logs.slice(0, 50)));
    }

    function renderStockTable() {
        const stockDb = JSON.parse(localStorage.getItem('stockDatabase')) || [];
        const recordsBody = document.getElementById('entryRecordsBody');
        // Clear except the default ones if any, but better to just manage via DB
        recordsBody.innerHTML = stockDb.map(item => `
            <tr class="hover:bg-surface-container-low transition-colors">
                <td class="px-6 py-4 font-bold">${item.name}</td>
                <td class="px-6 py-4 text-right">${item.qty} ${item.unit}</td>
                <td class="px-6 py-4">Depo / Stok</td>
                <td class="px-6 py-4 text-right">Az önce</td>
            </tr>
        `).join('') + recordsBody.innerHTML;
    }

    // CSV Dışa Aktarma (Export Report)
    function exportToCSV() {
        const rows = [["TABLO", "KOLON1", "KOLON2", "KOLON3", "KOLON4", "KOLON5", "KOLON6"]];
        const tableConfigs = [
            { tableId: "stockTableBody", label: "Bekleyen Siparisler" },
            { tableId: "entryRecordsBody", label: "Veri Giris Kayitlari" },
            { tableId: "materialDatabaseBody", label: "Diger Malzemeler" }
        ];

        tableConfigs.forEach(config => {
            const tableRows = document.querySelectorAll(`#${config.tableId} tr`);
            tableRows.forEach(row => {
                const cols = Array.from(row.querySelectorAll("td")).map(td => td.innerText.trim());
                rows.push([config.label, ...cols]);
            });
        });

        const csvContent = "data:text/csv;charset=utf-8," + rows.map(e => e.join(",")).join("\n");
        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", "depo_raporu.csv");
        document.body.appendChild(link);
        link.click();
        alert("Rapor CSV olarak indiriliyor...");
    }

    // Kamera Kontrolü
    let stream = null;
    let scanInterval = null;
    let barcodeDetector = null;
    let zxingReader = null;
    let qrCanvas = null;
    let qrCtx = null;
    let scanLocked = false;

    function setScanStatus(text) {
        const status = document.getElementById('scanStatusText');
        if (status) status.textContent = text;
    }

    function resetScanFrame() {
        const frame = document.getElementById('scanFrame');
        if (!frame) return;
        frame.classList.remove('border-secondary', 'border-primary/50');
        frame.classList.add('border-primary/50');
    }

    function setScanSuccessFrame() {
        const frame = document.getElementById('scanFrame');
        if (!frame) return;
        frame.classList.remove('border-primary/50');
        frame.classList.add('border-secondary');
    }

    function processBarcodeValue(code) {
        if (scanLocked) return;
        scanLocked = true;
        document.getElementById('entryMaterialId').value = code;
        setScanSuccessFrame();
        setScanStatus(`Basarili! Kod okundu: ${code}`);
        setTimeout(() => {
            stopCamera();
            const entryModal = document.getElementById('entryModal');
            if (entryModal.classList.contains('hidden')) {
                toggleModal('entryModal');
            }
            scanLocked = false;
        }, 900);
    }

    function applyManualCode() {
        const input = document.getElementById('manualCodeInput');
        const manualCode = input.value.trim();
        if (!manualCode) {
            setScanStatus("Lutfen gecerli bir kod giriniz");
            return;
        }
        processBarcodeValue(manualCode);
    }

    async function startCamera() {
    try {
        scanLocked = false;
        resetScanFrame();
        setScanStatus("Barkod aranıyor... (Lütfen 20cm uzakta tutun)");
        
        // Gelişmiş kamera ayarları
        const constraints = {
            video: {
                facingMode: { ideal: "environment" },
                // Netlik için çözünürlüğü bir tık artırdık ama işlemciyi yormayacak seviyede
                width: { min: 640, ideal: 1280, max: 1920 },
                height: { min: 480, ideal: 720, max: 1080 },
                // Bazı modern tarayıcılar için odak desteği
                focusMode: "continuous"
            }
        };

        stream = await navigator.mediaDevices.getUserMedia(constraints);
        const preview = document.getElementById('preview');
        preview.srcObject = stream;
        await preview.play();

        if (window.ZXing) {
            // Barkod formatlarını zorlayarak hızı artırıyoruz (EAN_13 videodaki barkod tipidir)
            // startCamera içindeki hints kısmını bununla değiştir:
            const hints = new Map();
            hints.set(window.ZXing.DecodeHintType.POSSIBLE_FORMATS, [
                window.ZXing.BarcodeFormat.EAN_13, // Videodaki ürün barkodu
                window.ZXing.BarcodeFormat.CODE_128,
                window.ZXing.BarcodeFormat.QR_CODE
            ]);
            hints.set(window.ZXing.DecodeHintType.TRY_HARDER, true);
            hints.set(window.ZXing.DecodeHintType.ASSUME_GS1, true); // Standart barkodlar için ek destek
            zxingReader = new window.ZXing.BrowserMultiFormatReader(hints);
            
            zxingReader.decodeFromVideoElementContinuously(preview, (result, err) => {
                if (scanLocked) return;

                if (result) {
                    console.log("Başarılı:", result.text);
                    processBarcodeValue(result.text);
                    // Başarı anında görsel geri bildirim
                    document.getElementById('scanFrame').style.borderColor = "#22c55e"; 
                }
            });
        }
    } catch (err) {
        console.error("Kamera hatası:", err);
        setScanStatus("Kamera başlatılamadı. Lütfen izinleri kontrol edin.");
    }
}

    function stopCamera() {
        if (scanInterval) {
            clearInterval(scanInterval);
            scanInterval = null;
        }
        if (stream) {
            stream.getTracks().forEach(track => track.stop());
            stream = null;
        }
        if (zxingReader) {
            try {
                zxingReader.reset();
            } catch (e) {
                // ignore cleanup errors
            }
            zxingReader = null;
        }
        resetScanFrame();
        const modal = document.getElementById('scannerModal');
        if (!modal.classList.contains('hidden')) {
            toggleModal('scannerModal');
        }
    }

    // Form Gönderimi
    document.getElementById('newEntryForm').onsubmit = function(e) {
        e.preventDefault();
        const productName = document.getElementById('entryProductName').value.trim();
        const quantity = document.getElementById('entryQuantity').value.trim();
        const unit = document.getElementById('entryUnit').value;
        const department = document.getElementById('entryDepartment').value;
        const dateValue = document.getElementById('entryDate').value;
        const materialId = document.getElementById('entryMaterialId').value || 'MAN-ENTRY';

        if (!productName || !quantity || !dateValue) {
            alert("Lütfen ürün, miktar ve tarih alanlarını doldurun.");
            return;
        }

        // Save to Database
        const stockDb = JSON.parse(localStorage.getItem('stockDatabase')) || [];
        stockDb.push({
            id: Date.now(),
            name: productName,
            sku: materialId,
            qty: quantity,
            unit: unit,
            status: 'Sağlıklı',
            dept: department
        });
        localStorage.setItem('stockDatabase', JSON.stringify(stockDb));

        // Log Event
        logSystemEvent('Alex Sterling', `New Stock Entry: ${productName}`, 'Warehouse', 'SUCCESS');

        const formattedDate = new Date(dateValue).toLocaleDateString("tr-TR", {
            day: "2-digit",
            month: "long",
            year: "numeric"
        });

        const newRow = document.createElement("tr");
        newRow.className = "hover:bg-surface-container-low transition-colors";
        newRow.innerHTML = `
            <td class="px-6 py-4 font-bold">${productName}</td>
            <td class="px-6 py-4 text-right">${quantity} ${unit}</td>
            <td class="px-6 py-4">${department}</td>
            <td class="px-6 py-4 text-right">${formattedDate}</td>
        `;
        document.getElementById('entryRecordsBody').prepend(newRow);

        alert("Yeni veri başarıyla kaydedildi!");
        toggleModal('entryModal');
        this.reset();
    };

    // Load initial data
    renderStockTable();

    document.getElementById('manualCodeApplyBtn').addEventListener('click', applyManualCode);
    document.getElementById('manualCodeInput').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            applyManualCode();
        }
    });
</script>

</body>
</html>
