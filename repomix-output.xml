      <button id="declineKvkkBtn" class="px-6 py-2.5 rounded-full text-slate-600 font-bold text-sm hover:bg-slate-100 transition-colors">İptal Et</button>
      <button id="acceptKvkkBtn" class="bg-secondary text-white px-8 py-2.5 rounded-full font-bold text-sm shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all flex items-center gap-2">
