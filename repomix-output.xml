                    <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Onay Durumu</p>
                    <p id="detailStatus" class="text-sm font-bold mt-1 text-primary">Beklemede</p>
                </div>
                <div class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100">
                    <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Sorumlu (BT)</p>
                    <div class="flex justify-center mt-1">
                        <div id="detailAssigneeAvatar" class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold border-2 border-white shadow-sm"></div>
                    </div>
                </div>
            </div>

            <!-- Conditional Section: Task Progress -->
            <div id="taskProgressSection" class="hidden animate-in fade-in slide-in-from-top-2 duration-300">
                <div onclick="cycleTaskStatus()" class="bg-primary/5 p-4 rounded-2xl border border-primary/10 cursor-pointer hover:bg-primary/10 transition-all flex justify-between items-center">
                    <div>
                        <p class="text-[10px] uppercase font-bold text-primary/60 tracking-wider">İş Süreci Durumu</p>
                        <p id="detailTaskStatus" class="text-lg font-bold text-primary">Yapılıyor</p>
                    </div>
                    <span class="material-symbols-outlined text-primary">sync</span>
                </div>
            </div>

            <!-- Conditional Section: Rejection Reason -->
            <div id="rejectionSection" class="hidden animate-in fade-in slide-in-from-top-2 duration-300">
                <label class="text-[10px] uppercase font-bold text-error tracking-wider mb-1 block">Red Nedeni</label>
                <textarea id="rejectionReason" oninput="saveRejectionReason()" placeholder="Red sebebini buraya yazınız..." class="w-full bg-error/5 border border-error/20 rounded-2xl p-4 text-sm text-error-container focus:ring-error focus:border-error min-h-[100px]"></textarea>
            </div>

            <div class="grid grid-cols-2 gap-6 bg-slate-50 p-4 rounded-2xl border border-slate-100">
                <div>
                    <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Departman</p>
                    <p id="detailDept" class="text-sm font-bold text-slate-700"></p>
                </div>
                <div>
                    <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Talep Eden</p>
                    <p id="detailSender" class="text-sm font-bold text-slate-700"></p>
                </div>
            </div>

            <div>
                <h4 class="font-bold text-slate-800 flex items-center gap-2 mb-2 text-sm">
                    <span class="material-symbols-outlined text-sm text-primary">description</span>
                    Talep Açıklaması
                </h4>
                <p id="detailDescription" class="text-xs text-slate-600 bg-slate-50 p-4 rounded-2xl leading-relaxed mb-6">
                    Sistem üzerinde API geçit yolunda sürekli zaman aşımı hataları alınıyor.
                </p>
            </div>

            <!-- New Section: Final Action -->
            <div class="pt-4 border-t border-slate-100 space-y-4">
                <div class="space-y-2">
                    <label class="text-[10px] uppercase font-bold text-slate-400 tracking-wider ml-1">İlgili Departmanı Seç / Güncelle</label>
                    <select id="detailDeptSelect" class="w-full bg-slate-50 border border-slate-200 rounded-2xl p-3 text-sm font-medium outline-none focus:ring-2 focus:ring-primary/20 transition-all">
                        <option value="Üretim">Üretim</option>
                        <option value="Finans">Finans</option>
                        <option value="İK">İnsan Kaynakları</option>
                        <option value="Lojistik">Lojistik</option>
                        <option value="Satın Alma">Satın Alma</option>
                        <option value="Yönetim">Yönetim</option>
                    </select>
                </div>
                
                <button onclick="sendTicketUpdate()" class="w-full py-4 bg-primary text-white rounded-2xl font-bold shadow-lg shadow-primary/20 hover:scale-[1.01] active:scale-[0.99] transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">send</span>
                    Güncelle ve Bilgilendir
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let currentTicketIndex = -1;
    const defaultTickets = [
        { id: 1, title: 'API Gateway Zaman Aşımı', requester: 'Mark V.', dept: 'Üretim', time: '12 dk önce', priority: 'Yüksek', status: 'Beklemede', taskStatus: 'Başlanmadı', rejectionReason: '', icon: 'priority_high', iconClass: 'bg-error-container/30 text-error', badgeClass: 'bg-error-container text-on-error-container', assignee: 'AS', assigneeColor: 'bg-primary/20 text-primary', border: 'border-l-4 border-error', description: 'API Gateway katmanında 504 Gateway Timeout hataları alınıyor. Kritik sistemler veri senkronizasyonu yapamıyor.' },
        { id: 2, title: 'Veritabanı İndeks Optimizasyonu', requester: 'Sarah K.', dept: 'Finans', time: '1 sa önce', priority: 'Orta', status: 'Onaylandı', taskStatus: 'Yapılıyor', rejectionReason: '', icon: 'database', iconClass: 'bg-secondary-container/30 text-secondary', badgeClass: 'bg-secondary-container text-on-secondary-container', assignee: 'SK', assigneeColor: 'bg-secondary/20 text-secondary', border: '', description: 'Personel sorguları 5 saniyenin üzerinde sürmeye başladı. İndekslerin yeniden yapılandırılması gerekiyor.' },
        { id: 3, title: 'Yeni Geliştirici İşe Alımı', requester: 'Caner L.', dept: 'İK', time: '4 sa önce', priority: 'Düşük', status: 'Reddedildi', taskStatus: 'Başlanmadı', rejectionReason: 'Bütçe planlaması henüz onaylanmadı.', icon: 'person_add', iconClass: 'bg-surface-container-high text-slate-500', badgeClass: 'bg-surface-container-high text-on-surface-variant', assignee: 'MV', assigneeColor: 'bg-slate-200 text-slate-600', border: '', description: 'Yeni işe giren personel için gerekli sistem yetkileri tanımlanmalı.' }
    ];

    function loadTicketsSummary() {
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        if (!tickets) {
            tickets = defaultTickets;
            localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
        } else {
            tickets = tickets.map((t, index) => ({
                ...defaultTickets[index % defaultTickets.length],
                ...t
            }));
        }
        renderTicketsSummary(tickets.slice(0, 3));
    }

    function renderTicketsSummary(tickets) {
        const container = document.getElementById('ticketsSummaryContainer');
        if (!container) return;
        container.innerHTML = tickets.map((ticket, index) => {
            const allTickets = JSON.parse(localStorage.getItem('it_support_tickets'));
            const originalIndex = allTickets.findIndex(t => t.id === ticket.id);

            return `
            <div class="p-6 flex items-center justify-between hover:bg-slate-50 transition-all hover:translate-x-1 ${ticket.border || ''}">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full ${ticket.iconClass} flex items-center justify-center">
                        <span class="material-symbols-outlined">${ticket.icon}</span>
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <p class="font-bold text-slate-800">${ticket.title}</p>
                            <span class="px-2 py-0.5 rounded-md text-[8px] font-black uppercase ${getStatusBadgeClass(ticket.status)}">${ticket.status}</span>
                        </div>
                        <p class="text-[10px] text-slate-500">${ticket.dept} Departmanı • ${ticket.requester} • ${ticket.time}</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button onclick="openTicketDetailModal(${originalIndex})" class="px-4 py-1.5 bg-slate-100 hover:bg-primary hover:text-white transition-all text-slate-600 rounded-lg text-[10px] font-bold uppercase">Detay</button>
                    <div class="w-8 h-8 rounded-full ${ticket.assigneeColor} flex items-center justify-center font-bold text-[10px] border-2 border-white shadow-sm" title="Sorumlu: ${ticket.assignee}">
                        ${ticket.assignee}
                    </div>
                </div>
            </div>
        `}).join('');
    }

    function getStatusBadgeClass(status) {
        if (status === 'Onaylandı') return 'bg-green-100 text-green-700';
        if (status === 'Reddedildi') return 'bg-red-100 text-red-700';
        if (status === 'İnceleniyor') return 'bg-blue-100 text-blue-700';
        return 'bg-slate-100 text-slate-500';
    }

    function openTicketDetailModal(index) {
        currentTicketIndex = index;
        const tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        const ticket = tickets[index];

        document.getElementById('detailTitle').innerText = ticket.title;
        document.getElementById('detailRequesterTime').innerText = ticket.time;
        document.getElementById('detailDescription').innerText = ticket.description || 'Açıklama bulunmuyor.';
        document.getElementById('detailDept').innerText = ticket.dept || 'Belirtilmedi';
        document.getElementById('detailSender').innerText = ticket.requester || 'Belirtilmedi';
        
        const iconContainer = document.getElementById('detailIconContainer');
        iconContainer.className = `w-12 h-12 rounded-2xl flex items-center justify-center ${ticket.iconClass}`;
        document.getElementById('detailIcon').innerText = ticket.icon;

        updatePriorityDisplay(ticket.priority);
        updateStatusDisplay(ticket.status);
        updateAssigneeDisplay(ticket.assignee, ticket.assigneeColor);
        updateTaskProgressUI(ticket.status, ticket.taskStatus);
        
        document.getElementById('rejectionReason').value = ticket.rejectionReason || '';
        document.getElementById('detailDeptSelect').value = ticket.dept || 'Üretim';

        document.getElementById('ticketDetailModal').classList.remove('hidden');
    }

    function sendTicketUpdate() {
        if (currentTicketIndex === -1) return;
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        
        // Save current selections
        tickets[currentTicketIndex].dept = document.getElementById('detailDeptSelect').value;
        tickets[currentTicketIndex].rejectionReason = document.getElementById('rejectionReason').value;
        
        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
        
        // Visual feedback
        const btn = event.currentTarget;
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="material-symbols-outlined text-sm">check_circle</span> Bilgilendirme Gönderildi';
        btn.classList.replace('bg-primary', 'bg-green-600');
        
        setTimeout(() => {
            closeTicketDetailModal();
            loadTicketsSummary();
            // Reset button for next time
            btn.innerHTML = originalHtml;
            btn.classList.replace('bg-green-600', 'bg-primary');
            addLog(`INFO: Update sent to ${tickets[currentTicketIndex].dept} department.`);
        }, 1000);
    }

    function updateTaskProgressUI(status, taskStatus) {
        const taskSection = document.getElementById('taskProgressSection');
        const rejectSection = document.getElementById('rejectionSection');
        const taskEl = document.getElementById('detailTaskStatus');

        if (status === 'Onaylandı' || status === 'İnceleniyor') {
            taskSection.classList.remove('hidden');
            rejectSection.classList.add('hidden');
            taskEl.innerText = (taskStatus || 'Başlanmadı').toUpperCase();
        } else if (status === 'Reddedildi') {
            taskSection.classList.add('hidden');
            rejectSection.classList.remove('hidden');
        } else {
            taskSection.classList.add('hidden');
            rejectSection.classList.add('hidden');
        }
    }

    function saveRejectionReason() {
        if (currentTicketIndex === -1) return;
        const reason = document.getElementById('rejectionReason').value;
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        tickets[currentTicketIndex].rejectionReason = reason;
        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
    }

    function updatePriorityDisplay(priority) {
        const el = document.getElementById('detailPriority');
        el.innerText = priority.toUpperCase();
        let cls = 'bg-surface-container-high text-on-surface-variant';
        if (priority === 'Yüksek') cls = 'bg-error-container text-on-error-container';
        if (priority === 'Orta') cls = 'bg-secondary-container text-on-secondary-container';
        el.className = `text-[10px] font-bold mt-1 px-2 py-0.5 rounded-full inline-block ${cls}`;
    }

    function updateStatusDisplay(status) {
        const el = document.getElementById('detailStatus');
        el.innerText = status || 'Beklemede';
        el.className = `text-sm font-bold mt-1 ${status === 'Tamamlandı' ? 'text-green-600' : (status === 'İnceleniyor' ? 'text-primary' : 'text-slate-400')}`;
    }

    function updateAssigneeDisplay(name, color) {
        const el = document.getElementById('detailAssigneeAvatar');
        el.innerText = name;
        el.className = `w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold border-2 border-white shadow-sm ${color}`;
    }

    function cyclePriority() {
        if (currentTicketIndex === -1) return;
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        const priorities = ['Düşük', 'Orta', 'Yüksek'];
        let idx = priorities.indexOf(tickets[currentTicketIndex].priority);
        let next = priorities[(idx + 1) % priorities.length];
        tickets[currentTicketIndex].priority = next;
        
        if (next === 'Yüksek') {
            tickets[currentTicketIndex].badgeClass = 'bg-error-container text-on-error-container';
            tickets[currentTicketIndex].border = 'border-l-4 border-error';
        } else if (next === 'Orta') {
            tickets[currentTicketIndex].badgeClass = 'bg-secondary-container text-on-secondary-container';
            tickets[currentTicketIndex].border = '';
        } else {
            tickets[currentTicketIndex].badgeClass = 'bg-surface-container-high text-on-surface-variant';
            tickets[currentTicketIndex].border = '';
        }

        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
        updatePriorityDisplay(next);
        loadTicketsSummary();
        addLog(`INFO: Ticket priority updated to ${next}`);
    }

    function cycleStatus() {
        if (currentTicketIndex === -1) return;
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        const statuses = ['Beklemede', 'Onaylandı', 'İnceleniyor', 'Reddedildi'];
        let idx = statuses.indexOf(tickets[currentTicketIndex].status || 'Beklemede');
        let next = statuses[(idx + 1) % statuses.length];
        tickets[currentTicketIndex].status = next;

        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
        updateStatusDisplay(next);
        updateTaskProgressUI(next, tickets[currentTicketIndex].taskStatus);
        loadTicketsSummary();
        addLog(`INFO: Ticket status updated to ${next}`);
    }

    function cycleAssignee() {
        if (currentTicketIndex === -1) return;
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        const assignees = [
            { name: 'AS', color: 'bg-primary/20 text-primary' },
            { name: 'SK', color: 'bg-secondary/20 text-secondary' },
            { name: 'MV', color: 'bg-slate-200 text-slate-600' }
        ];
        let idx = assignees.findIndex(a => a.name === tickets[currentTicketIndex].assignee);
        let next = assignees[(idx + 1) % assignees.length];
        tickets[currentTicketIndex].assignee = next.name;
        tickets[currentTicketIndex].assigneeColor = next.color;

        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
        updateAssigneeDisplay(next.name, next.color);
        loadTicketsSummary();
        addLog(`INFO: Ticket assigned to ${next.name}`);
    }

    function cycleTaskStatus() {
        if (currentTicketIndex === -1) return;
        let tickets = JSON.parse(localStorage.getItem('it_support_tickets'));
        const taskStatuses = ['Başlanmadı', 'Yapılıyor', 'Tamamlandı'];
        let idx = taskStatuses.indexOf(tickets[currentTicketIndex].taskStatus || 'Başlanmadı');
        let next = taskStatuses[(idx + 1) % taskStatuses.length];
        tickets[currentTicketIndex].taskStatus = next;

        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));
        document.getElementById('detailTaskStatus').innerText = next.toUpperCase();
        loadTicketsSummary();
    }

    function closeTicketDetailModal() {
        document.getElementById('ticketDetailModal').classList.add('hidden');
        currentTicketIndex = -1;
    }

    function refreshTelemetry() {
        const btn = document.getElementById('refreshBtn');
        const text = document.getElementById('refreshText');
        const icon = document.getElementById('refreshIcon');
        const lastSync = document.getElementById('lastSyncTime');

        btn.disabled = true;
        text.innerText = "Güncelleniyor...";
        icon.classList.remove('hidden');

        // Simulate Spring Boot / N-Tier Service response
        setTimeout(() => {
            btn.disabled = false;
            text.innerText = "Telemetriyi Güncelle";
            icon.classList.add('hidden');
            lastSync.innerText = new Date().toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            
            // Add a "success" log to the terminal
            addLog("INFO: SystemMetrics refreshed from Repository layer.");
        }, 1500);
    }

    function addLog(msg) {
        const terminal = document.getElementById('terminalLogs');
        const now = new Date().toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const p = document.createElement('p');
        p.className = msg.includes('INFO') ? 'text-green-400' : 'text-slate-400';
        p.innerHTML = `<span class="text-slate-500">[${now}]</span> ${msg}`;
        terminal.appendChild(p);
        
        // Remove first log if too many
        if (terminal.children.length > 8) {
            terminal.removeChild(terminal.firstChild);
        }
    }

    // Auto-scrolling logs simulation
    setInterval(() => {
        const logs = [
            "DEBUG: Monitoring node Sector-7G...",
            "INFO: Heartbeat sent to API Gateway.",
            "DEBUG: Cache hit ratio: 94%",
            "INFO: IoT Hub connected - Port 8080"
        ];
        if (Math.random() > 0.7) {
            addLog(logs[Math.floor(Math.random() * logs.length)]);
        }
    }, 4000);

    function openModal() {
        document.getElementById('ticketModal').classList.remove('hidden');
    }
    
    function closeModal() {
        document.getElementById('ticketModal').classList.add('hidden');
    }

    function submitTicket() {
        const title = document.getElementById('ticketTitle').value;
        const priority = document.getElementById('ticketPriority').value;
        
        if (!title) return alert('Lütfen bir başlık girin!');

        const newTicket = {
            id: Date.now(),
            title: title,
            requester: 'Alex Sterling',
            time: 'Şimdi',
            priority: priority,
            icon: 'confirmation_number',
            iconClass: 'bg-primary/20 text-primary',
            badgeClass: priority === 'Yüksek' ? 'bg-error-container text-on-error-container' : (priority === 'Orta' ? 'bg-secondary-container text-on-secondary-container' : 'bg-surface-container-high text-on-surface-variant'),
            assignee: 'AS',
            assigneeColor: 'bg-primary/20 text-primary',
            border: priority === 'Yüksek' ? 'border-l-4 border-error' : ''
        };

        let tickets = JSON.parse(localStorage.getItem('it_support_tickets')) || [];
        tickets.unshift(newTicket);
        localStorage.setItem('it_support_tickets', JSON.stringify(tickets));

        addLog(`INFO: New ticket created - ${title}`);
        loadTicketsSummary();
        closeModal();
        document.getElementById('ticketTitle').value = '';
    }

    document.addEventListener('DOMContentLoaded', loadTicketsSummary);
</script>
<!-- Contextual FAB -->
<div class="fixed bottom-8 right-8 z-50">
<button onclick="openModal()" class="w-16 h-16 bg-primary text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all">
<span class="material-symbols-outlined text-3xl">add</span>
</button>
</div>
<!-- Mobile Navigation -->
<nav class="md:hidden fixed bottom-0 left-0 w-full bg-slate-50/90 backdrop-blur-lg border-t border-slate-200/50 flex justify-around items-center h-16 px-4 z-50">
<button class="text-blue-700 flex flex-col items-center">
<span class="material-symbols-outlined">dashboard</span>
<span class="text-[10px] font-bold">Panel</span>
</button>
<button class="text-slate-400 flex flex-col items-center">
<span class="material-symbols-outlined">dns</span>
<span class="text-[10px]">Sunucular</span>
</button>
<button class="text-slate-400 flex flex-col items-center">
<span class="material-symbols-outlined">confirmation_number</span>
<span class="text-[10px]">Talepler</span>
</button>
<button class="text-slate-400 flex flex-col items-center">
<span class="material-symbols-outlined">settings</span>
<span class="text-[10px]">Yapılandır</span>
</button>
</nav>
</body></html>
