      <!-- Filter Chips -->
      <div class="flex flex-wrap gap-2 mt-6" id="filterContainer">
        <button onclick="filterTickets('Hepsi')"
          class="filter-chip active px-4 py-2 rounded-full text-xs font-bold transition-all border border-primary/20 bg-primary text-white">Tümü</button>
        <button onclick="filterTickets('Beklemede')"
          class="filter-chip px-4 py-2 rounded-full text-xs font-bold transition-all border border-slate-200 bg-white text-slate-600 hover:bg-slate-50">Bekleyenler</button>
        <button onclick="filterTickets('Onaylandı')"
          class="filter-chip px-4 py-2 rounded-full text-xs font-bold transition-all border border-slate-200 bg-white text-slate-600 hover:bg-slate-50">Onaylananlar</button>
        <button onclick="filterTickets('İnceleniyor')"
          class="filter-chip px-4 py-2 rounded-full text-xs font-bold transition-all border border-slate-200 bg-white text-slate-600 hover:bg-slate-50">Yapım
          Aşamasında</button>
        <button onclick="filterTickets('Reddedildi')"
          class="filter-chip px-4 py-2 rounded-full text-xs font-bold transition-all border border-slate-200 bg-white text-slate-600 hover:bg-slate-50">Reddedilenler</button>
      </div>

      <style>
        .filter-chip.active {
          background: #2b54bf !important;
          color: white !important;
          border-color: #2b54bf !important;
        }
      </style>

      <!-- Modal: Ticket Details -->
      <div id="ticketDetailModal"
        class="fixed inset-0 z-[100] hidden flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4">
        <div class="bg-white rounded-3xl p-8 w-full max-w-2xl shadow-2xl border border-outline-variant/20">
          <div class="flex justify-between items-center mb-6">
            <div class="flex items-center gap-4">
              <div id="detailIconContainer" class="w-12 h-12 rounded-2xl flex items-center justify-center">
                <span id="detailIcon" class="material-symbols-outlined">confirmation_number</span>
              </div>
              <div>
                <h3 id="detailTitle" class="font-headline font-bold text-2xl text-on-surface">Talep Detayı</h3>
                <p id="detailRequester" class="text-sm text-slate-500"></p>
              </div>
            </div>
            <button onclick="closeDetailModal()"
              class="w-10 h-10 rounded-full hover:bg-slate-100 flex items-center justify-center transition-colors">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>

          <div class="space-y-6">
            <div class="grid grid-cols-3 gap-4">
              <div onclick="cyclePriority()"
                class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100 cursor-pointer transition-all hover:bg-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Öncelik</p>
                <p id="detailPriority" class="text-[10px] font-bold mt-1 px-2 py-0.5 rounded-full inline-block"></p>
              </div>
              <div onclick="cycleStatus()"
                class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100 cursor-pointer transition-all hover:bg-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Onay Durumu</p>
                <p id="detailStatus" class="text-sm font-bold mt-1 text-primary">Açık</p>
              </div>
              <div onclick="cycleAssignee()" class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100 cursor-pointer transition-all hover:bg-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Sorumlu (BT)</p>
                <div class="flex justify-center mt-1">
                  <div id="detailAssigneeAvatar"
                    class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold border-2 border-white shadow-sm">
                  </div>
                </div>
              </div>
            </div>

            <!-- Conditional Section: Task Progress -->
            <div id="taskProgressSection" class="hidden animate-in fade-in slide-in-from-top-2 duration-300">
              <div onclick="cycleTaskStatus()"
                class="bg-primary/5 p-4 rounded-2xl border border-primary/10 cursor-pointer hover:bg-primary/10 transition-all flex justify-between items-center">
                <div>
                  <p class="text-[10px] uppercase font-bold text-primary/60 tracking-wider">İş Süreci Durumu</p>
                  <p id="detailTaskStatus" class="text-lg font-bold text-primary">Yapılıyor</p>
                </div>
                <span class="material-symbols-outlined text-primary">sync</span>
              </div>
            </div>

            <!-- Conditional Section: Rejection Reason -->
            <div id="rejectionSection" class="hidden animate-in fade-in slide-in-from-top-2 duration-300">
              <label class="text-[10px] uppercase font-bold text-error tracking-wider mb-1 block">Red Nedeni</label>
              <textarea id="rejectionReason" oninput="saveRejectionReason()"
                placeholder="Red sebebini buraya yazınız..."
                class="w-full bg-error/5 border border-error/20 rounded-2xl p-4 text-sm text-error-container focus:ring-error focus:border-error min-h-[100px]"></textarea>
            </div>

            <div class="grid grid-cols-2 gap-6 bg-slate-50 p-4 rounded-2xl border border-slate-100">
              <div>
