  <!-- Main Content -->
  <main class="lg:ml-72 pt-28 px-8 pb-12">
    <div class="max-w-7xl mx-auto space-y-8">
      <!-- Header Section -->
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h2 class="font-headline font-extrabold text-4xl text-on-surface tracking-tight">Merkezi Destek Yönetimi</h2>
          <p class="text-on-surface-variant mt-2">Diğer departmanlardan gelen teknik talep ve onay süreçleri.</p>
