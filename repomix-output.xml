  </style>
</head>

<body>

  <aside class="sidebar">
    <div class="sidebar-brand"><span class="sidebar-logo">Industrial Pulse</span></div>
    <nav class="sidebar-nav">
      <a class="nav-item" href="hr.html"><i class="material-icons-round">dashboard</i>Anasayfa</a>
      <a class="nav-item" href="personel.html"><i class="material-icons-round">groups</i>Personel (İK)</a>
      <a class="nav-item" href="bordro.html"><i class="material-icons-round">receipt_long</i>Maaş & Bordro</a>
      <a class="nav-item active" href="egitim.html"><i class="material-icons-round">school</i>Eğitim</a>
    </nav>
  </aside>

  <div class="main-wrap">
    <div class="topbar">
      <span class="topbar-title">Eğitim Yönetimi</span>
      <a href="hr.html" class="btn-back"><i class="material-icons-round">arrow_back</i>İK Merkezine Dön</a>
    </div>

    <div class="content">
      <div class="card">
        <div class="entry-section">
          <h3
            style="font-size:11px; color:var(--text-muted); margin-bottom:12px; text-transform:uppercase; letter-spacing:1px">
            Yeni Eğitim Kaydı</h3>
          <form class="entry-form" id="eduForm">
            <div class="field"><label>Personel</label><input type="text" id="e_name" placeholder="Ad Soyad" required>
            </div>
            <div class="field">
              <label>Departman</label>
              <select id="e_dept" required>
                <option value="">Seçin...</option>
                <option>Üretim</option>
                <option>Ar-Ge</option>
                <option>BTBS</option>
                <option>İK</option>
                <option>Operasyon</option>
                <option>Pazarlama</option>
              </select>
            </div>
            <div class="field"><label>Eğitim Konusu</label><input type="text" id="e_subject" placeholder="Eğitim adı"
                required></div>
            <div class="field"><label>Bitiş Tarihi</label><input type="date" id="e_date"></div>
            <div class="field" style="flex-direction:row; gap:8px; align-items:center; padding-bottom:8px">
              <input type="checkbox" id="e_isIndefinite" style="width:16px; height:16px"> <label
                style="margin:0">Süresiz</label>
            </div>
            <button type="submit" class="btn-add"><i class="material-icons-round">add</i>Kaydet</button>
          </form>
        </div>

        <div class="table-controls">
          <div class="search-box">
            <i class="material-icons-round">search</i>
            <input type="text" id="tableSearch" placeholder="Arama yapın..." onkeyup="render()">
          </div>
          <div class="filter-tabs">
            <div class="tab active" data-filter="current" onclick="setFilter('current')">Ana Tablo</div>
            <div class="tab" data-filter="all" onclick="setFilter('all')">Tüm Eğitimler</div>
            <div class="tab" data-filter="indefinite" onclick="setFilter('indefinite')">Süresiz</div>
            <div class="tab" data-filter="history" onclick="setFilter('history')">Geçmiş Eğitimler</div>
          </div>
        </div>

        <table>
          <thead>
            <tr>
              <th>Personel</th>
              <th>Konu</th>
              <th>Bitiş Tarihi</th>
              <th>Durum</th>
              <th style="text-align:right">İşlem</th>
            </tr>
          </thead>
          <tbody id="eduTable"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Edit/Update Modal -->
  <div class="modal-overlay" id="editModal">
    <div class="modal">
      <div class="modal-header">
        <h2 style="font-size:15px; font-weight:600" id="modalTitle">Eğitimi Güncelle</h2>
        <button class="btn-icon" onclick="closeModal()" style="background:none"><i
            class="material-icons-round">close</i></button>
      </div>
      <div class="modal-body">
        <div id="modalNote"
          style="padding:10px; border-radius:8px; background:#eff6ff; color:#2563eb; font-size:12px; margin-bottom:8px; display:none">
          Bu eğitimin süresi dolmuş. Güncelleme yapıldığında eski kayıt geçmişe aktarılacak, yeni bir kayıt
          eklenecektir.
        </div>
        <div class="field"><label>Yeni Bitiş Tarihi</label><input type="date" id="m_newDate"></div>
        <div class="field" style="flex-direction:row; gap:8px; align-items:center; padding-top:8px">
          <input type="checkbox" id="m_isIndefinite" style="width:16px; height:16px"> <label style="margin:0">Süresiz
            Yap</label>
        </div>
      </div>
      <div class="modal-footer">
        <button class="tab" onclick="closeModal()">İptal</button>
        <button class="btn-add" onclick="saveUpdate()">Güncelle</button>
      </div>
    </div>
  </div>

  <script>
    const LS_KEY = 'factory_trainings';
    let activeId = null;
    let currentFilter = 'current';

    function getTrainings() { return JSON.parse(localStorage.getItem(LS_KEY) || '[]'); }
    function saveTrainings(data) { localStorage.setItem(LS_KEY, JSON.stringify(data)); }

    function calculateStatus(dateStr, isIndefinite) {
      if (isIndefinite) return 'active';
      if (!dateStr) return 'active';
      const diff = (new Date(dateStr) - new Date()) / (1000 * 60 * 60 * 24);
      if (diff < 0) return 'expired';
      if (diff < 15) return 'warning';
      return 'active';
    }

    function setFilter(f) {
      currentFilter = f;
      document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.filter === f));
      render();
    }

    function render() {
      const list = getTrainings();
      const tbody = document.getElementById('eduTable');
      const search = document.getElementById('tableSearch').value.toLowerCase();

      // Filtreleme
      let filtered = list.filter(item => {
        const isMatch = item.name.toLowerCase().includes(search) || item.subject.toLowerCase().includes(search);
        if (!isMatch) return false;

        const status = calculateStatus(item.date, item.isIndefinite);

        if (currentFilter === 'current') return (status === 'expired' || status === 'warning') && !item.isHistory;
        if (currentFilter === 'indefinite') return item.isIndefinite && !item.isHistory;
        if (currentFilter === 'history') return item.isHistory;
        if (currentFilter === 'all') return !item.isHistory;
        return true;
      });

      // Sıralama Mantığı
      filtered.sort((a, b) => {
        if (currentFilter === 'all' || currentFilter === 'history') return b.id - a.id; // Yeni -> Eski

        const sA = calculateStatus(a.date, a.isIndefinite);
        const sB = calculateStatus(b.date, b.isIndefinite);

        const priority = { 'expired': 1, 'warning': 2, 'active': 3 };
        if (priority[sA] !== priority[sB]) return priority[sA] - priority[sB];

        // Bitiş tarihi önceliği (yakın olan üstte)
        if (a.date && b.date) return new Date(a.date) - new Date(b.date);
        return 0;
      });

      tbody.innerHTML = filtered.map(item => {
        const status = calculateStatus(item.date, item.isIndefinite);
        const sLabel = item.isHistory ? 'GEÇMİŞ' : (item.isIndefinite ? 'SÜRESİZ' : (status === 'active' ? 'AKTİF' : (status === 'expired' ? 'DOLDU' : 'YAKLAŞIYOR')));
        const sClass = item.isHistory ? 'pill-history' : (status === 'active' ? 'pill-active' : (status === 'expired' ? 'pill-expired' : 'pill-warning'));
        const rowClass = !item.isHistory && status === 'expired' ? 'row-expired' : (status === 'warning' ? 'row-warning' : '');

        return `<tr class="${rowClass}">
        <td><b>${item.name}</b><br><small>${item.dept}</small></td>
        <td>${item.subject}${item.isIndefinite ? ' <span style="color:var(--accent); font-size:10px; font-weight:700">(SÜRESİZ)</span>' : ''}</td>
        <td>${item.isIndefinite ? '-' : (item.date || '-')}</td>
        <td><span class="status-pill ${sClass}">${sLabel}</span></td>
        <td style="text-align:right">
          ${item.isHistory ? '<small style="color:var(--text-muted)">Geçmiş Eğitim</small>' :
            `<button class="btn-icon btn-edit" onclick="openModal(${item.id})"><i class="material-icons-round" style="font-size:18px">settings_backup_restore</i></button>`}
        </td>
      </tr>`;
      }).join('') || '<tr><td colspan="5" style="text-align:center; padding:40px; color:var(--text-muted)">Gösterilecek kayıt bulunamadı.</td></tr>';
    }

    function openModal(id) {
      activeId = id;
      const list = getTrainings();
      const item = list.find(x => x.id === id);
      const status = calculateStatus(item.date, item.isIndefinite);

      document.getElementById('modalTitle').textContent = item.isIndefinite ? "Eğitim Bilgilerini Düzenle" : "Eğitimi Güncelle";
      document.getElementById('modalNote').style.display = (status === 'expired') ? 'block' : 'none';
      document.getElementById('m_newDate').value = item.date || '';
      document.getElementById('m_isIndefinite').checked = item.isIndefinite;
      document.getElementById('editModal').classList.add('open');
    }

    function closeModal() { document.getElementById('editModal').classList.remove('open'); activeId = null; }

    function saveUpdate() {
      const list = getTrainings();
      const item = list.find(x => x.id === activeId);
      const status = calculateStatus(item.date, item.isIndefinite);
      const newDate = document.getElementById('m_newDate').value;
      const newIndefinite = document.getElementById('m_isIndefinite').checked;

      if (status === 'expired') {
        // Eski kaydı geçmişe at
        item.isHistory = true;
        // Yeni kayıt ekle
        list.push({
          id: Date.now(),
          name: item.name,
          dept: item.dept,
          subject: item.subject,
          date: newIndefinite ? '' : newDate,
          isIndefinite: newIndefinite,
          isHistory: false
        });
      } else {
        // Normal düzenleme
        item.date = newIndefinite ? '' : newDate;
        item.isIndefinite = newIndefinite;
      }

      saveTrainings(list);
      closeModal();
      render();
    }

    document.getElementById('eduForm').addEventListener('submit', e => {
      e.preventDefault();
      const list = getTrainings();
      list.push({
        id: Date.now(),
        name: document.getElementById('e_name').value,
        dept: document.getElementById('e_dept').value,
        subject: document.getElementById('e_subject').value,
        date: document.getElementById('e_isIndefinite').checked ? '' : document.getElementById('e_date').value,
        isIndefinite: document.getElementById('e_isIndefinite').checked,
        isHistory: false
      });
      saveTrainings(list);
      e.target.reset();
      render();
    });

    document.getElementById('e_isIndefinite').addEventListener('change', e => {
      document.getElementById('e_date').disabled = e.target.checked;
      if (e.target.checked) document.getElementById('e_date').value = '';
    });

    render();
  </script>
</body>

</html>
