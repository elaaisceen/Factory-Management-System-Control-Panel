<script>
  (function () {
    // ─── localStorage yardımcıları ───────────────────────────────────
    const DB_KEY = 'purchasingDatabase';
    const LOG_KEY = 'systemLogs';

    function getDb() {
      return JSON.parse(localStorage.getItem(DB_KEY)) || [];
    }
    function saveDb(db) {
      localStorage.setItem(DB_KEY, JSON.stringify(db));
    }
    function logSystemEvent(action, location) {
      const logs = JSON.parse(localStorage.getItem(LOG_KEY)) || [];
      logs.unshift({ user: 'Satın Alma', action, location, time: new Date().toISOString(), status: 'SUCCESS' });
      localStorage.setItem(LOG_KEY, JSON.stringify(logs.slice(0, 50)));
    }

    // ─── Toast bildirimi ─────────────────────────────────────────────
    function showToast(message, type) {
      const existing = document.getElementById('purchaseToast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.id = 'purchaseToast';
      const bg = type === 'error' ? 'bg-red-600' : 'bg-slate-900';
      toast.className = `fixed top-24 right-6 ${bg} text-white text-sm font-semibold px-5 py-3 rounded-xl shadow-2xl z-[200] flex items-center gap-2`;
      toast.innerHTML = `<span class="material-symbols-outlined text-base">${type === 'error' ? 'error' : 'check_circle'}</span> ${message}`;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 2500);
    }

    // ─── Element referansları ────────────────────────────────────────
    const exportButton = document.getElementById('exportReportBtn');
    const newOrderButton = document.getElementById('newPurchaseOrderBtn');
    const purchaseModal = document.getElementById('purchaseFormModal');
    const purchaseModalOverlay = document.getElementById('purchaseModalOverlay');
    const closePurchaseModalBtn = document.getElementById('closePurchaseModalBtn');
    const cancelPurchaseModalBtn = document.getElementById('cancelPurchaseModalBtn');
    const purchaseRequestForm = document.getElementById('purchaseRequestForm');
    const departmentSelect = document.getElementById('departmentSelect');
    const requestTitle = document.getElementById('requestTitle');
    const itemName = document.getElementById('itemName');
    const supplierName = document.getElementById('supplierName');
    const amountInput = document.getElementById('amountInput');
    const prioritySelect = document.getElementById('prioritySelect');
    const activePoContainer = document.querySelector('.space-y-6'); // Aktif PO listesi

    // ─── Modal açma / kapama ─────────────────────────────────────────
    function openNewOrderFlow(defaultDepartment) {
      if (!purchaseModal) return;
      purchaseModal.classList.remove('hidden');
      if (departmentSelect) departmentSelect.value = defaultDepartment || '';
      if (requestTitle) requestTitle.focus();
    }
    function closeNewOrderFlow() {
      if (!purchaseModal) return;
      purchaseModal.classList.add('hidden');
    }

    // ─── Aktif PO listesine yeni kart ekle ──────────────────────────
    function renderPoCard(order) {
      if (!activePoContainer) return;
      const statusLabel = {
        Pending: 'Beklemede', 'On Way': 'Yolda', 'Quality Inspection': 'Kalite Kontrol'
      }[order.status] || order.status;
      const card = document.createElement('div');
      card.className = 'bg-surface-container-lowest p-6 rounded-lg shadow-sm';
      card.dataset.poId = order.id;
      card.innerHTML = `
        <div class="flex justify-between items-start mb-4">
          <div>
            <h4 class="font-bold text-primary">${order.id}: ${order.item}</h4>
            <p class="text-xs text-outline font-medium">Tedarikçi: ${order.supplier}</p>
          </div>
          <span class="text-xs font-black text-on-surface">Miktar: ${order.qty}</span>
        </div>
        <div class="relative pt-1">
          <div class="flex mb-2 items-center justify-between">
            <div class="text-xs font-semibold inline-block py-1 px-2 uppercase rounded-full text-primary bg-primary-fixed">${statusLabel}</div>
            <div class="text-right"><span class="text-xs font-semibold inline-block text-primary">0%</span></div>
          </div>
          <div class="overflow-hidden h-3 mb-4 text-xs flex rounded-full bg-surface-container">
            <div class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-primary" style="width:5%"></div>
          </div>
        </div>`;
      activePoContainer.prepend(card);
    }

    // ─── Bekleyen onay tablosuna yeni satır ekle ─────────────────────
    function renderApprovalRow(order) {
      const tbody = document.querySelector('tbody');
      if (!tbody) return;
      const tr = document.createElement('tr');
      tr.className = 'border-b border-outline-variant/5 group hover:bg-surface-container-low transition-colors';
      tr.dataset.poId = order.id;
      tr.innerHTML = `
        <td class="py-4 px-2 font-mono text-xs">${order.id}</td>
        <td class="py-4 px-2">
          <p class="font-bold">${order.item}</p>
          <span class="text-[10px] text-outline">Departman: ${order.department || 'Belirtilmedi'}</span>
        </td>
        <td class="py-4 px-2 font-bold">$${parseFloat(order.amount || 0).toLocaleString('tr-TR')}</td>
        <td class="py-4 px-2 text-right">
          <div class="flex justify-end gap-2">
            <button class="approve-btn w-8 h-8 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-sm">check</span>
            </button>
            <button class="reject-btn w-8 h-8 rounded-full bg-error-container text-on-error-container flex items-center justify-center hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-sm">close</span>
            </button>
          </div>
        </td>`;
      // Onay/red butonları
      tr.querySelector('.approve-btn').addEventListener('click', () => {
        updateOrderStatus(order.id, 'Onaylandı');
        tr.remove();
        showToast(`${order.id} onaylandı.`);
      });
      tr.querySelector('.reject-btn').addEventListener('click', () => {
        updateOrderStatus(order.id, 'Reddedildi');
        tr.remove();
        showToast(`${order.id} reddedildi.`);
      });
      tbody.prepend(tr);
    }

    function updateOrderStatus(id, status) {
      const db = getDb();
      const idx = db.findIndex(o => o.id === id);
      if (idx !== -1) {
        db[idx].status = status;
        saveDb(db);
        logSystemEvent(`Talep ${status}: ${id}`, 'Satın Alma');
      }
    }

    // ─── Sayfa yüklenince mevcut siparişleri render et ───────────────
    function loadExistingOrders() {
      const db = getDb();
      db.slice().reverse().forEach(order => {
        renderPoCard(order);
        if (!['Onaylandı', 'Reddedildi', 'Teslim Edildi'].includes(order.status)) {
          renderApprovalRow(order);
        }
      });
    }

    // ─── Export CSV ──────────────────────────────────────────────────
    if (exportButton) {
      exportButton.addEventListener('click', () => {
        const db = getDb();
        const csvRows = [
          ['Sipariş ID', 'Tedarikçi', 'Ürün / Servis', 'Miktar', 'Tutar', 'Departman', 'Öncelik', 'Durum', 'Tarih'],
          ...db.map(o => [o.id, o.supplier || '', o.item, o.qty || '', `$${o.amount || 0}`, o.department || '', o.priority || '', o.status, o.date || ''])
        ];
        const csv = csvRows.map(row => row.map(v => `"${String(v).replaceAll('"', '""')}"`).join(',')).join('\n');
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url; link.download = 'satin-alma-raporu.csv';
        document.body.appendChild(link); link.click(); link.remove();
        URL.revokeObjectURL(url);
        showToast('Rapor dışa aktarıldı.');
      });
    }

    // ─── Form gönderimi ──────────────────────────────────────────────
    if (purchaseRequestForm) {
      purchaseRequestForm.addEventListener('submit', (event) => {
        event.preventDefault();
        const timestamp = Date.now();
        const title = requestTitle?.value?.trim() || 'Yeni Talep';
        const selectedItem = itemName?.value?.trim() || 'Ürün / Servis';
        const selectedDepartment = departmentSelect?.value || 'Belirtilmedi';
        const selectedSupplier = supplierName?.value?.trim() || '';
        const selectedAmount = amountInput?.value || '0';
        const selectedPriority = prioritySelect?.value || 'Normal';
        const dateStr = new Date().toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' });

        const newOrder = {
          id: 'PO-' + timestamp.toString().slice(-4),
          title: title,
          item: selectedItem,
          supplier: selectedSupplier,
          qty: 1,
          amount: selectedAmount,
          department: selectedDepartment,
          priority: selectedPriority,
          status: 'Pending',
          date: dateStr
        };

        // localStorage'a kaydet
        const db = getDb();
        db.push(newOrder);
        saveDb(db);

        // Sistem loguna yaz
        logSystemEvent(`Yeni Satın Alma: ${selectedItem}`, 'Satın Alma');

        // UI'a ekle
        renderPoCard(newOrder);
        renderApprovalRow(newOrder);

        showToast(`${title} talebi oluşturuldu (${selectedDepartment}).`);
        purchaseRequestForm.reset();
        closeNewOrderFlow();
        if (newOrderButton) newOrderButton.focus();
      });
    }

    // ─── Butonlar ────────────────────────────────────────────────────
    if (newOrderButton) newOrderButton.addEventListener('click', () => openNewOrderFlow(''));
    if (purchaseModalOverlay) purchaseModalOverlay.addEventListener('click', closeNewOrderFlow);
    if (closePurchaseModalBtn) closePurchaseModalBtn.addEventListener('click', closeNewOrderFlow);
    if (cancelPurchaseModalBtn) cancelPurchaseModalBtn.addEventListener('click', closeNewOrderFlow);

    // ─── Mevcut hardcoded onay satırlarına event ekle ────────────────
    document.querySelectorAll('tbody tr').forEach(row => {
      const approveBtn = row.querySelector('button:nth-child(1)');
      const rejectBtn = row.querySelector('button:nth-child(2)');
      const reqId = row.querySelector('td')?.textContent?.trim() || 'Talep';
      if (approveBtn) approveBtn.addEventListener('click', () => { row.remove(); showToast(reqId + ' onaylandı.'); });
      if (rejectBtn) rejectBtn.addEventListener('click', () => { row.remove(); showToast(reqId + ' reddedildi.'); });
    });

    // ─── Sayfa yükleme ───────────────────────────────────────────────
    loadExistingOrders();
  })();
</script>
</body></html>
