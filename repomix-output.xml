                    <!-- Tickets will load here -->
                </div>
            </div>
        </div>
    </main>

    <script>
        // Helper to log system events
        function logSystemEvent(user, action, location, status) {
            const logs = JSON.parse(localStorage.getItem('systemLogs')) || [];
            logs.unshift({
                user: user,
                action: action,
                location: location,
                time: new Date().toISOString(),
                status: status
            });
            localStorage.setItem('systemLogs', JSON.stringify(logs.slice(0, 50)));
        }

        function submitTicket() {
            const title = document.getElementById('reqTitle').value;
            const dept = document.getElementById('reqDept').value;
            const desc = document.getElementById('reqDesc').value;

            if (!title || !desc) return alert('Lütfen zorunlu alanları doldurun!');

            const newTicket = {
                id: Date.now(),
                title: title,
                requester: 'Alex Sterling',
                dept: dept,
                time: 'Şimdi',
                priority: 'Orta',
                status: 'Beklemede',
                taskStatus: 'Başlanmadı',
                icon: 'support',
                iconClass: 'bg-primary/10 text-primary',
                assignee: 'BT Ekibi',
                assigneeColor: 'bg-slate-200 text-slate-600',
                description: desc
            };

            let tickets = JSON.parse(localStorage.getItem('it_support_tickets')) || [];
            tickets.unshift(newTicket);
            localStorage.setItem('it_support_tickets', JSON.stringify(tickets));

            // Log Event
            logSystemEvent('Alex Sterling', `IT Support Request: ${title}`, 'Support Center', 'SUCCESS');

            document.getElementById('successMsg').classList.remove('hidden');
            document.getElementById('reqTitle').value = '';
            document.getElementById('reqDesc').value = '';
            
            setTimeout(() => {
                document.getElementById('successMsg').classList.add('hidden');
                loadMyTickets();
            }, 2000);
        }

        function loadMyTickets() {
            const tickets = JSON.parse(localStorage.getItem('it_support_tickets')) || [];
            // Filter for Alex Sterling's tickets
            const myTickets = tickets.filter(t => t.requester === 'Alex Sterling');
            
            const container = document.getElementById('myTicketsContainer');
            if (myTickets.length === 0) {
                container.innerHTML = '<div class="p-12 text-center text-slate-400 font-medium">Henüz bir talebiniz bulunmuyor.</div>';
                return;
            }

            container.innerHTML = myTickets.map(t => `
                <div class="p-6 hover:bg-slate-50 transition-all">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full ${t.iconClass || 'bg-slate-100 text-slate-500'} flex items-center justify-center">
                                <span class="material-symbols-outlined">${t.icon || 'confirmation_number'}</span>
                            </div>
                            <div>
                                <div class="flex items-center gap-2">
                                    <p class="font-bold text-slate-800">${t.title}</p>
                                    <span class="px-2 py-0.5 rounded-md text-[8px] font-black uppercase ${getStatusClass(t.status)}">${t.status}</span>
                                </div>
                                <p class="text-[10px] text-slate-500">${t.time} • ${t.dept}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Süreç Durumu</p>
                            <p class="text-xs font-black text-primary mt-1">${(t.taskStatus || 'Hazırlanıyor').toUpperCase()}</p>
                        </div>
                    </div>
                    
                    ${t.status === 'Reddedildi' && t.rejectionReason ? `
                        <div class="mt-4 p-4 bg-red-50 rounded-2xl border border-red-100">
                            <p class="text-[10px] font-bold text-red-600 uppercase mb-1">BT Yanıtı (Red Nedeni)</p>
                            <p class="text-xs text-red-800">${t.rejectionReason}</p>
                        </div>
                    ` : ''}

                    ${t.status === 'Onaylandı' ? `
                        <div class="mt-4 p-4 bg-green-50 rounded-2xl border border-green-100">
                            <p class="text-[10px] font-bold text-green-600 uppercase mb-1">BT Yanıtı</p>
                            <p class="text-xs text-green-800">Talebiniz onaylandı ve iş listesine alındı. BT Uzmanı: ${t.assignee}</p>
                        </div>
                    ` : ''}
                </div>
            `).join('');
        }

        function getStatusClass(status) {
            if (status === 'Onaylandı') return 'bg-green-100 text-green-700';
            if (status === 'Reddedildi') return 'bg-red-100 text-red-700';
            if (status === 'İnceleniyor') return 'bg-blue-100 text-blue-700';
            return 'bg-slate-100 text-slate-500';
        }

        document.addEventListener('DOMContentLoaded', loadMyTickets);
        // Polling for updates every 5 seconds to simulate real-time response
        setInterval(loadMyTickets, 5000);
    </script>
</body>
