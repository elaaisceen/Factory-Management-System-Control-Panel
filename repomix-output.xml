<script>
    const recentSearchInput = document.getElementById("recentSearchInput");
    const recentDepartmentFilter = document.getElementById("recentDepartmentFilter");
    const recentStatusFilter = document.getElementById("recentStatusFilter");
    const recentRows = Array.from(document.querySelectorAll("#recentTransactionsBody tr"));

    function recentCloseMenus() {
        document.querySelectorAll(".recent-action-menu").forEach(menu => menu.classList.add("hidden"));
    }

    // Helper to log system events
    function logSystemEvent(user, action, location, status) {
        const logs = JSON.parse(localStorage.getItem('systemLogs')) || [];
        logs.unshift({
            user: user,
            action: action,
            location: location,
            time: new Date().toISOString(),
            status: status
        });
        localStorage.setItem('systemLogs', JSON.stringify(logs.slice(0, 50)));
    }

    function renderFinanceTable() {
        const finDb = JSON.parse(localStorage.getItem('financeDatabase')) || [];
        const tbody = document.getElementById('recentTransactionsBody');
        tbody.innerHTML = finDb.map(item => `
            <tr class="hover:bg-slate-50 transition-colors" data-department="Finance" data-status="${item.status}">
                <td class="px-8 py-5 text-sm font-bold text-on-surface">#${item.id}</td>
                <td class="px-8 py-5">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center">
                            <span class="material-symbols-outlined text-sm text-slate-400">payments</span>
                        </div>
                        <div>
                            <p class="text-sm font-semibold">${item.company}</p>
                            <p class="text-[10px] text-slate-500">${item.detail}</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-5 text-sm text-on-surface-variant font-medium">Finans</td>
                <td class="px-8 py-5 text-sm text-on-surface-variant font-medium">${item.date}</td>
                <td class="px-8 py-5 text-sm font-bold text-on-surface">-$${parseFloat(item.amount).toLocaleString()}</td>
                <td class="px-8 py-5 text-center">
                    <span class="${recentBadgeClass(item.status)}">${item.status}</span>
                </td>
                <td class="px-8 py-5 text-right relative"></td>
            </tr>
        `).join('') + tbody.innerHTML;
    }

    function recentBadgeClass(status) {
        if (status === "Ödendi") return "recent-status-badge px-3 py-1 rounded-full text-[10px] font-bold bg-secondary/10 text-secondary border border-secondary/20";
        if (status === "Gecikti") return "recent-status-badge px-3 py-1 rounded-full text-[10px] font-bold bg-error/10 text-error border border-error/20";
        return "recent-status-badge px-3 py-1 rounded-full text-[10px] font-bold bg-primary/10 text-primary border border-primary/20";
    }

    function recentApplyFilters() {
        const q = recentSearchInput.value.trim().toLowerCase();
        const dep = recentDepartmentFilter.value;
        const st = recentStatusFilter.value;

        recentRows.forEach(row => {
            const textMatch = row.innerText.toLowerCase().includes(q);
            const depMatch = dep === "all" || row.dataset.department === dep;
            const stMatch = st === "all" || row.dataset.status === st;
            row.style.display = textMatch && depMatch && stMatch ? "" : "none";
        });
    }

    function recentUpdateStatus(row, newStatus) {
        row.dataset.status = newStatus;
        const badge = row.querySelector(".recent-status-badge");
        badge.textContent = newStatus;
        badge.className = recentBadgeClass(newStatus);
        const actionCell = row.querySelector("td:last-child");
        if (newStatus !== "İşlem Bekliyor") {
            actionCell.innerHTML = "";
        }
        recentCloseMenus();
        recentApplyFilters();
    }

    recentSearchInput.addEventListener("input", recentApplyFilters);
    recentDepartmentFilter.addEventListener("change", recentApplyFilters);
    recentStatusFilter.addEventListener("change", recentApplyFilters);

    document.querySelectorAll(".recent-action-trigger").forEach(trigger => {
        trigger.addEventListener("click", (event) => {
            event.stopPropagation();
            const menu = trigger.parentElement.querySelector(".recent-action-menu");
            const isHidden = menu.classList.contains("hidden");
            recentCloseMenus();
            if (isHidden) menu.classList.remove("hidden");
        });
    });

    document.querySelectorAll(".recent-approve-btn").forEach(btn => {
        btn.addEventListener("click", (event) => {
            const row = event.target.closest("tr");
            recentUpdateStatus(row, "Ödendi");
        });
    });

    document.querySelectorAll(".recent-reject-btn").forEach(btn => {
        btn.addEventListener("click", (event) => {
            const row = event.target.closest("tr");
            recentUpdateStatus(row, "Gecikti");
        });
    });

    // Initialize data
    renderFinanceTable();

    document.addEventListener("click", recentCloseMenus);
</script>
