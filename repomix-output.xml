    tr:hover {
      background: #f9fafb;
    }

    .row-expired {
      background: #fff1f2;
    }

    .row-warning {
      background: #fffbeb;
    }

    .status-pill {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }

    .pill-active {
      background: var(--ok-bg);
      color: var(--ok-text);
    }

    .pill-expired {
      background: var(--bad-bg);
      color: var(--bad-text);
    }

    .pill-warning {
      background: var(--warn-bg);
      color: var(--warn-text);
    }

    .pill-history {
      background: #f1f5f9;
      color: #475569;
