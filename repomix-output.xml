<script>
    let currentUserIndex = -1;
    const defaultUsers = [
        { initials: 'AS', name: 'Alex Sterling', dept: 'Yönetim', role: 'Fabrika Müdürü', access: 'Tam Erişim', status: 'Ofisten', accessClass: 'bg-primary/20 text-primary', lastLogin: 'Şimdi', color: 'bg-primary/10 text-primary' },
        { initials: 'MV', name: 'Mark V.', dept: 'BT', role: 'Sistem Admin', access: 'Yönetici', status: 'Remote', accessClass: 'bg-secondary/20 text-secondary', lastLogin: '12 dk önce', color: 'bg-secondary/10 text-secondary' },
        { initials: 'SK', name: 'Sarah K.', dept: 'Üretim', role: 'Operatör', access: 'Sınırlı', status: 'Hibrit', accessClass: 'bg-slate-100 text-slate-500', lastLogin: '2 sa önce', color: 'bg-slate-100 text-slate-500' }
    ];

    function loadUsers() {
        let users = JSON.parse(localStorage.getItem('it_user_management'));
        if (!users) {
            users = defaultUsers;
            localStorage.setItem('it_user_management', JSON.stringify(users));
        } else {
            // Sync with default styling if fields are missing
            users = users.map((u, i) => ({
                ...defaultUsers[i % defaultUsers.length],
                status: u.status || 'Ofisten',
                ...u
            }));
        }
        renderUsers(users);
    }

    function renderUsers(users) {
        const tbody = document.getElementById('usersTableBody');
        tbody.innerHTML = users.map((user, index) => `
            <tr class="hover:bg-slate-50 transition-colors text-sm">
                <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full ${user.color} flex items-center justify-center font-bold text-xs">${user.initials}</div>
                        <span class="font-bold text-slate-800">${user.name}</span>
                    </div>
                </td>
                <td class="px-6 py-4 text-slate-500">${user.dept}</td>
                <td class="px-6 py-4 text-slate-500">${user.role}</td>
                <td class="px-6 py-4">
                    <span class="px-3 py-1 ${user.accessClass} rounded-full text-[10px] font-bold uppercase tracking-wider">${user.access}</span>
                </td>
                <td class="px-6 py-4 text-slate-500">${user.lastLogin}</td>
                <td class="px-6 py-4">
                    <button onclick="openUserDetailModal(${index})" class="text-primary hover:underline font-semibold">Detaylar</button>
                </td>
            </tr>
        `).join('');
    }

    function openAddModal() {
        document.getElementById('addUserModal').classList.remove('hidden');
    }

    function closeAddModal() {
        document.getElementById('addUserModal').classList.add('hidden');
        document.getElementById('userName').value = '';
        document.getElementById('userDept').value = '';
    }

    function submitUser() {
        const name = document.getElementById('userName').value;
        const dept = document.getElementById('userDept').value;
        const role = document.getElementById('userRole').value;
        const access = document.getElementById('userAccess').value;

        if (!name || !dept) return alert('Lütfen tüm alanları doldurun!');

        const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
        
        let accessClass = 'bg-primary/20 text-primary';
        if (access === 'Yönetici') accessClass = 'bg-secondary/20 text-secondary';
        if (access === 'Sınırlı') accessClass = 'bg-slate-100 text-slate-500';

        const newUser = {
            initials: initials,
            name: name,
            dept: dept,
            role: role,
            access: access,
            status: 'Ofisten',
            accessClass: accessClass,
            lastLogin: 'Şimdi',
            color: 'bg-primary/10 text-primary'
        };

        let users = JSON.parse(localStorage.getItem('it_user_management')) || [];
        users.push(newUser);
        localStorage.setItem('it_user_management', JSON.stringify(users));

        loadUsers();
        closeAddModal();
    }

    function openUserDetailModal(index) {
        currentUserIndex = index;
        const users = JSON.parse(localStorage.getItem('it_user_management'));
        const user = users[index];

        document.getElementById('detailUserName').innerText = user.name;
        document.getElementById('detailUserDept').innerText = user.dept;
        document.getElementById('detailUserDeptInfo').innerText = user.dept;
        document.getElementById('detailLastLogin').innerText = user.lastLogin;
        
        const avatar = document.getElementById('detailAvatar');
        avatar.innerText = user.initials;
        avatar.className = `w-12 h-12 rounded-2xl flex items-center justify-center font-bold text-xl ${user.color}`;

        updateStatusDisplay(user.status || 'Ofisten');
        updateAccessDisplay(user.access);
        updateRoleDisplay(user.role);

        document.getElementById('userDetailModal').classList.remove('hidden');
    }

    function updateStatusDisplay(status) {
        const el = document.getElementById('detailUserStatus');
        el.innerText = status.toUpperCase();
        let cls = 'bg-green-100 text-green-700'; // Ofisten
        if (status === 'Remote') cls = 'bg-blue-100 text-blue-700';
        if (status === 'Hibrit') cls = 'bg-purple-100 text-purple-700';
        el.className = `text-[10px] font-bold mt-1 px-2 py-0.5 rounded-full inline-block ${cls}`;
    }

    function updateAccessDisplay(access) {
        const el = document.getElementById('detailUserAccess');
        el.innerText = access.toUpperCase();
        let cls = 'bg-primary/20 text-primary';
        if (access === 'Yönetici') cls = 'bg-secondary/20 text-secondary';
        if (access === 'Sınırlı') cls = 'bg-slate-100 text-slate-500';
        el.className = `text-[10px] font-bold mt-1 px-2 py-0.5 rounded-full inline-block ${cls}`;
    }

    function updateRoleDisplay(role) {
        document.getElementById('detailUserRole').innerText = role;
    }

    function cycleStatus() {
        if (currentUserIndex === -1) return;
        let users = JSON.parse(localStorage.getItem('it_user_management'));
        const statuses = ['Ofisten', 'Remote', 'Hibrit'];
        let idx = statuses.indexOf(users[currentUserIndex].status || 'Ofisten');
        let next = statuses[(idx + 1) % statuses.length];
        users[currentUserIndex].status = next;

        localStorage.setItem('it_user_management', JSON.stringify(users));
        updateStatusDisplay(next);
        loadUsers();
    }

    function openEditModal() {
        if (currentUserIndex === -1) return;
        const users = JSON.parse(localStorage.getItem('it_user_management'));
        const user = users[currentUserIndex];

        document.getElementById('editUserName').value = user.name;
        document.getElementById('editUserDept').value = user.dept;
        document.getElementById('editUserRole').value = user.role;
        document.getElementById('editUserAccess').value = user.access;

        document.getElementById('editUserModal').classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editUserModal').classList.add('hidden');
    }

    function saveUserEdits() {
        if (currentUserIndex === -1) return;
        let users = JSON.parse(localStorage.getItem('it_user_management'));
        const user = users[currentUserIndex];

        const newName = document.getElementById('editUserName').value;
        const newDept = document.getElementById('editUserDept').value;
        const newRole = document.getElementById('editUserRole').value;
        const newAccess = document.getElementById('editUserAccess').value;

        if (!newName || !newDept) return alert('Lütfen zorunlu alanları doldurun!');

        user.name = newName;
        user.dept = newDept;
        user.role = newRole;
        user.access = newAccess;
        user.initials = newName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
        
        // Update access class
        if (newAccess === 'Tam Erişim') user.accessClass = 'bg-primary/20 text-primary';
        else if (newAccess === 'Yönetici') user.accessClass = 'bg-secondary/20 text-secondary';
        else user.accessClass = 'bg-slate-100 text-slate-500';

        localStorage.setItem('it_user_management', JSON.stringify(users));
        
        openUserDetailModal(currentUserIndex); // Refresh detail modal
        loadUsers(); // Refresh table
        closeEditModal();
    }

    function closeUserDetailModal() {
        document.getElementById('userDetailModal').classList.add('hidden');
        currentUserIndex = -1;
    }

    document.addEventListener('DOMContentLoaded', loadUsers);
</script>
</body></html>
