<thead class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
<tr>
<th class="px-6 py-4 font-bold">Kullanıcı</th>
<th class="px-6 py-4 font-bold">Departman</th>
<th class="px-6 py-4 font-bold">Rol</th>
<th class="px-6 py-4 font-bold">Erişim Seviyesi</th>
<th class="px-6 py-4 font-bold">Son Giriş</th>
<th class="px-6 py-4 font-bold">İşlem</th>
</tr>
</thead>
<tbody class="divide-y divide-surface" id="usersTableBody">
    <!-- Users will be loaded here -->
</tbody>
