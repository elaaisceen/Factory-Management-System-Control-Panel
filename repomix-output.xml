          </div>
        </div>

        <button onclick="processExport()" class="w-full py-4 bg-primary text-white rounded-2xl font-bold shadow-lg shadow-primary/20 hover:shadow-xl active:scale-95 transition-all">Raporu Oluştur ve İndir</button>
      </div>
    </div>
  </div>

  <button onclick="openPersonnelModal()"
    class="fixed bottom-8 right-8 w-16 h-16 bg-primary text-white rounded-full shadow-2xl shadow-primary/40 flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50">
    <span class="material-symbols-outlined scale-125" data-icon="person_add">person_add</span>
  </button>

  <script>
    const LS_KEY = 'factory_personnel';
    const LS_TRAIN_KEY = 'factory_trainings';
    let currentReportType = 'dept';
    let currentFormat = 'pdf';

    // MODAL KONTROLLERİ
    function openPersonnelModal() { document.getElementById('personnelModal').classList.remove('hidden'); }
    function closePersonnelModal() { document.getElementById('personnelModal').classList.add('hidden'); }
    function openExportModal() { document.getElementById('exportModal').classList.remove('hidden'); }
    function closeExportModal() { document.getElementById('exportModal').classList.add('hidden'); }

    // RAPOR AYARLARI
    function setReportType(type) {
        currentReportType = type;
        document.getElementById('deptOptions').classList.toggle('hidden', type !== 'dept');
        document.getElementById('eduOptions').classList.toggle('hidden', type === 'dept');
        // Buton renklerini güncelle
        document.getElementById('btnReportDept').style.borderColor = type === 'dept' ? '#2b54bf' : '#e2e8f0';
        document.getElementById('btnReportEdu').style.borderColor = type === 'edu' ? '#2b54bf' : '#e2e8f0';
    }

    function setFormat(fmt) { currentFormat = fmt; }

    // RAPORU DIŞARI AKTAR (PROCESS EXPORT)
    function processExport() {
        const personnel = JSON.parse(localStorage.getItem(LS_KEY) || '[]');
        if (personnel.length === 0) { alert("Veri bulunamadı!"); return; }

        if (currentFormat === 'excel') {
            let csv = "Ad Soyad,Departman\n" + personnel.map(p => `${p.name},${p.dept}`).join('\n');
            const blob = new Blob([csv], { type: 'text/csv' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = "Rapor.csv";
            link.click();
        } else {
            window.print(); // Basit önizleme
        }
    }

    // PERSONEL KAYDET
    document.getElementById('personnelForm').addEventListener('submit', e => {
        e.preventDefault();
        const data = {
            id: Date.now(),
            name: document.getElementById('p_name').value,
            dept: document.getElementById('p_dept').value,
            expert: document.getElementById('p_expert').value,
            status: 'active'
        };
        const list = JSON.parse(localStorage.getItem(LS_KEY) || '[]');
        list.push(data);
        localStorage.setItem(LS_KEY, JSON.stringify(list));
        e.target.reset();
        closePersonnelModal();
        renderPersonnelTable();
    });

    // TABLOYU DOLDUR
    function renderPersonnelTable() {
        const list = JSON.parse(localStorage.getItem(LS_KEY) || '[]');
        const tbody = document.getElementById('shortPersonnelTable');
        const recentHires = document.getElementById('recentHiresList');

        // Tabloyu güncelle
        tbody.innerHTML = list.slice(-5).reverse().map(p => `
            <tr>
                <td class="p-4 font-bold">${p.name}</td>
                <td class="p-4">${p.dept}</td>
                <td class="p-4">${p.expert}</td>
                <td class="p-4"><span class="bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs">Aktif</span></td>
                <td class="p-4 text-right"><span class="material-symbols-outlined cursor-pointer">visibility</span></td>
            </tr>
        `).join('') || '<tr><td colspan="5" class="text-center p-8">Kayıt yok.</td></tr>';

        // Son eklenenler widget'ı
        recentHires.innerHTML = list.slice(-3).reverse().map(p => `
            <div class="flex items-center gap-4 p-4 bg-white rounded-xl shadow-sm mb-2">
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold">${p.name[0]}</div>
                <div><p class="font-bold text-sm">${p.name}</p><p class="text-xs text-gray-500">${p.dept}</p></div>
            </div>
        `).join('');
    }

    renderPersonnelTable();
</script>
</body>

</html>
