            <div class="flex items-center gap-4">
              <div id="detailPowerStatus" onclick="togglePower()"
                class="flex items-center gap-2 px-3 py-1 cursor-pointer transition-all hover:opacity-80 rounded-full text-[10px] font-bold border">
                <!-- Power status injected here -->
              </div>
              <button onclick="closeDetailModal()"
                class="w-10 h-10 rounded-full hover:bg-slate-100 flex items-center justify-center transition-colors">
                <span class="material-symbols-outlined">close</span>
              </button>
            </div>
          </div>

          <div class="space-y-8">
            <div class="grid grid-cols-4 gap-4">
              <div onclick="cycleStatus()"
                class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100 cursor-pointer transition-all hover:bg-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Durum</p>
                <p id="detailStatus" class="text-sm font-bold mt-1"></p>
              </div>
              <div class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">CPU</p>
                <p id="detailCPU" class="text-sm font-bold mt-1 text-slate-700"></p>
              </div>
              <div class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">RAM</p>
                <p id="detailRAM" class="text-sm font-bold mt-1 text-slate-700"></p>
              </div>
              <div onclick="cycleTaskStatus()"
                class="bg-slate-50 p-4 rounded-2xl text-center border border-slate-100 cursor-pointer transition-all hover:bg-slate-100">
                <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Görev</p>
                <p id="detailTaskStatus" class="text-[10px] font-bold mt-1 px-2 py-0.5 rounded-full inline-block"></p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-slate-800 flex items-center gap-2 mb-2 text-sm">
                  <span class="material-symbols-outlined text-sm text-primary">group</span>
                  Sorumlu Personeller
                </h4>
                <div id="detailPersonnel" class="flex flex-wrap gap-2 mb-4">
                  <!-- Personnel tags here -->
                </div>
                <h4 class="font-bold text-slate-800 flex items-center gap-2 mb-2 text-sm">
                  <span class="material-symbols-outlined text-sm text-primary">assignment</span>
                  İş Tanımı
                </h4>
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                  <p id="detailPurpose" class="text-xs text-slate-500 leading-relaxed"></p>
                </div>
              </div>
              <div>
                <h4 class="font-bold text-slate-800 flex items-center gap-2 mb-2 text-sm">
                  <span class="material-symbols-outlined text-sm text-primary">hub</span>
                  Erişimi Olan Birimler
                </h4>
                <div id="detailUsers" class="flex flex-wrap gap-2 mb-4">
                  <!-- Units will be listed here -->
                </div>
                <h4 class="font-bold text-slate-800 flex items-center gap-2 mb-2 text-sm">
                  <span class="material-symbols-outlined text-sm text-primary">memory</span>
                  Donanım Özeti
                </h4>
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 text-xs text-slate-600">
                  <p>Maksimum Kapasite: <span id="detailMaxRam" class="font-bold"></span></p>
                  <p class="mt-1">Sunucu Türü: Sanal Makine (VM)</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Servers Table -->
      <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/10 overflow-hidden">
        <table class="w-full text-left">
          <thead class="bg-surface-container-low text-on-surface-variant text-xs uppercase tracking-wider">
            <tr>
              <th class="px-6 py-4 font-bold">Sunucu Adı</th>
              <th class="px-6 py-4 font-bold">IP Adresi</th>
              <th class="px-6 py-4 font-bold">Durum</th>
              <th class="px-6 py-4 font-bold">CPU</th>
              <th class="px-6 py-4 font-bold">RAM</th>
              <th class="px-6 py-4 font-bold">İşlem</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface" id="serversTableBody">
            <!-- Servers will be loaded here -->
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    let currentDetailIndex = -1;
    const defaultServers = [
      { name: 'Ana Veritabanı (DB-01)', ip: '192.168.1.10', status: 'Çalışıyor', statusClass: 'bg-secondary-container text-on-secondary-container', cpu: '45%', ram: '8.2 GB', maxRam: '16 GB', personnel: 'Mark Sterling, Ela Aksoy', purpose: 'ERP Ana Veritabanı Bakımı', users: 'BT Ekibi, Finans', taskStatus: 'Yapılıyor', isPowerOn: true },
      { name: 'Uygulama Sunucusu (APP-01)', ip: '192.168.1.11', status: 'Çalışıyor', statusClass: 'bg-secondary-container text-on-secondary-container', cpu: '62%', ram: '12.5 GB', maxRam: '32 GB', personnel: 'Sarah Connor, Ahmet Yılmaz', purpose: 'Web Servisleri Dağıtımı', users: 'Yazılım Ekibi', taskStatus: 'Yapılıyor', isPowerOn: true },
      { name: 'Yedekleme Ünitesi (BKP-01)', ip: '192.168.1.20', status: 'Beklemede', statusClass: 'bg-surface-container-high text-on-surface-variant', cpu: '5%', ram: '2.1 GB', maxRam: '8 GB', personnel: 'John Doe', purpose: 'Haftalık Veri Arşivleme', users: 'BT Ekibi', taskStatus: 'Tamamlandı', isPowerOn: true },
      { name: 'Güvenlik Duvarı (FW-01)', ip: '192.168.1.1', status: 'Kritik', statusClass: 'bg-error-container text-on-error-container', cpu: '98%', ram: '3.9 GB', maxRam: '4 GB', personnel: 'Jane Smith', purpose: 'Ağ Güvenliği Analizi', users: 'Güvenlik Birimi', taskStatus: 'Yapılıyor', isPowerOn: true }
    ];

    function loadServers() {
      let servers = JSON.parse(localStorage.getItem('it_servers'));
      if (!servers) {
        servers = defaultServers;
        localStorage.setItem('it_servers', JSON.stringify(servers));
      } else {
        // Update logic for missing fields and ensure consistency
        servers = servers.map((s, i) => ({
          ...defaultServers[i % defaultServers.length], // Fill defaults first
          ...s // Override with saved data
        }));
      }
      renderServers(servers);
    }

    function renderServers(servers) {
      const tbody = document.getElementById('serversTableBody');
      if (!tbody) return;
      tbody.innerHTML = servers.map((server, index) => `
            <tr class="hover:bg-slate-50 transition-colors text-sm">
                <td class="px-6 py-4 font-bold text-slate-800">${server.name || 'İsimsiz'}</td>
                <td class="px-6 py-4 text-slate-500 font-mono">${server.ip || '-'}</td>
                <td class="px-6 py-4">
                    <span class="px-3 py-1 ${server.statusClass || 'bg-slate-100'} rounded-full text-[10px] font-bold uppercase tracking-wider">${server.status || 'Bilinmiyor'}</span>
                </td>
                <td class="px-6 py-4 text-slate-500">${server.cpu || '0%'}</td>
                <td class="px-6 py-4 text-slate-500">${server.ram || '0 GB'} / ${server.maxRam || '-'}</td>
                <td class="px-6 py-4">
                    <button onclick="openDetailModal(${index})" class="text-primary hover:text-blue-800 hover:underline font-bold transition-all">Detaylar</button>
                </td>
            </tr>
        `).join('');
    }

    // Modal Add
    function openAddModal() {
      document.getElementById('addServerModal').classList.remove('hidden');
    }
    function closeAddModal() {
      document.getElementById('addServerModal').classList.add('hidden');
    }

    function submitServer() {
      const name = document.getElementById('serverName').value;
      const ip = document.getElementById('serverIP').value;
      const personnel = document.getElementById('serverPersonnel').value;
      const maxRamValue = document.getElementById('serverMaxRam').value;
      const taskStatus = document.getElementById('serverTaskStatus').value;
      const isPowerOn = document.getElementById('serverPowerStatus').value === 'true';
      const status = document.getElementById('serverStatus').value;
      const purpose = document.getElementById('serverPurpose').value;
      const users = document.getElementById('serverUsers').value;

      if (!name || !ip) return alert('Lütfen zorunlu alanları doldurun!');

      let statusClass = 'bg-surface-container-high text-on-surface-variant';
      if (status === 'Çalışıyor') statusClass = 'bg-secondary-container text-on-secondary-container';
      if (status === 'Kritik') statusClass = 'bg-error-container text-on-error-container';

      const newServer = {
        name: name,
        ip: ip,
        personnel: personnel || 'Bilinmiyor',
        maxRam: maxRamValue ? maxRamValue + ' GB' : '16 GB',
        status: status,
        statusClass: statusClass,
        cpu: '0%',
        ram: '0 GB',
        purpose: purpose || 'Tanımlanmamış',
        users: users || 'Birimler Belirtilmedi',
        taskStatus: taskStatus,
        isPowerOn: isPowerOn
      };

      let servers = JSON.parse(localStorage.getItem('it_servers')) || [];
      servers.push(newServer);
      localStorage.setItem('it_servers', JSON.stringify(servers));

      loadServers();
      closeAddModal();
    }

    // Modal Details
    function openDetailModal(index) {
      currentDetailIndex = index;
      let servers = JSON.parse(localStorage.getItem('it_servers')) || defaultServers;
      const server = servers[index];
      if (!server) return;

      document.getElementById('detailName').innerText = server.name || 'Sunucu Detayı';
      document.getElementById('detailIP').innerText = server.ip || '-';
      document.getElementById('detailCPU').innerText = server.cpu || '0%';
      document.getElementById('detailRAM').innerText = server.ram || '0 GB';
      document.getElementById('detailMaxRam').innerText = server.maxRam || '-';
      document.getElementById('detailPurpose').innerText = server.purpose || 'İş tanımı belirtilmedi.';

      updateStatusDisplay(server.status || 'Beklemede');
      updateTaskDisplay(server.taskStatus || 'Yapılıyor');
      updatePowerDisplay(server.isPowerOn);

      const personnelContainer = document.getElementById('detailPersonnel');
      const personnelList = (server.personnel || 'Bilinmiyor').split(',');
      personnelContainer.innerHTML = personnelList.map(p => `
            <span class="px-3 py-1 bg-primary/10 text-primary rounded-lg text-xs font-bold border border-primary/10 flex items-center gap-2">
                <span class="material-symbols-outlined text-[14px]">person</span> ${p.trim()}
            </span>
        `).join('');

      const usersContainer = document.getElementById('detailUsers');
      const usersList = (server.users || 'Birimler Belirtilmedi').split(',');
      usersContainer.innerHTML = usersList.map(u => `
            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-lg text-xs font-semibold border border-slate-200">${u.trim()}</span>
        `).join('');

      document.getElementById('detailModal').classList.remove('hidden');
    }

    function updateStatusDisplay(status) {
      const el = document.getElementById('detailStatus');
      el.innerText = status;
      let cls = 'text-primary';
      if (status === 'Beklemede') cls = 'text-slate-400';
      if (status === 'Kritik') cls = 'text-error';
      el.className = `text-sm font-bold mt-1 ${cls}`;
    }

    function updateTaskDisplay(taskStatus) {
      const el = document.getElementById('detailTaskStatus');
      el.innerText = taskStatus.toUpperCase();
      let cls = 'bg-primary/10 text-primary';
      if (taskStatus === 'Tamamlandı') cls = 'bg-green-100 text-green-700';
      if (taskStatus === 'Başlanmadı') cls = 'bg-slate-100 text-slate-500';
      el.className = `text-[10px] font-bold mt-1 px-2 py-0.5 rounded-full inline-block ${cls}`;
    }

    function updatePowerDisplay(isOn) {
      const powerBadge = document.getElementById('detailPowerStatus');
      powerBadge.className = `flex items-center gap-2 px-3 py-1 cursor-pointer transition-all hover:opacity-80 rounded-full text-[10px] font-bold border ${isOn ? 'bg-green-50 text-green-700 border-green-200 shadow-[0_0_10px_rgba(34,197,94,0.1)]' : 'bg-slate-100 text-slate-500 border-slate-200'}`;
      powerBadge.innerHTML = `<div class="w-2 h-2 rounded-full ${isOn ? 'bg-green-500 animate-pulse' : 'bg-slate-400'}"></div> SUNUCU ${isOn ? 'AÇIK' : 'KAPALI'}`;
    }

    function togglePower() {
      if (currentDetailIndex === -1) return;
      let servers = JSON.parse(localStorage.getItem('it_servers'));
      servers[currentDetailIndex].isPowerOn = !servers[currentDetailIndex].isPowerOn;
      localStorage.setItem('it_servers', JSON.stringify(servers));
      updatePowerDisplay(servers[currentDetailIndex].isPowerOn);
      loadServers();
    }

    function cycleStatus() {
      if (currentDetailIndex === -1) return;
      let servers = JSON.parse(localStorage.getItem('it_servers'));
      const statuses = ['Çalışıyor', 'Beklemede', 'Kritik'];
      let idx = statuses.indexOf(servers[currentDetailIndex].status);
      servers[currentDetailIndex].status = statuses[(idx + 1) % statuses.length];

      // Update statusClass too
      let s = servers[currentDetailIndex].status;
      let cls = 'bg-surface-container-high text-on-surface-variant';
      if (s === 'Çalışıyor') cls = 'bg-secondary-container text-on-secondary-container';
      if (s === 'Kritik') cls = 'bg-error-container text-on-error-container';
      servers[currentDetailIndex].statusClass = cls;

      localStorage.setItem('it_servers', JSON.stringify(servers));
      updateStatusDisplay(servers[currentDetailIndex].status);
      loadServers();
    }

    function cycleTaskStatus() {
      if (currentDetailIndex === -1) return;
      let servers = JSON.parse(localStorage.getItem('it_servers'));
      const tasks = ['Başlanmadı', 'Yapılıyor', 'Tamamlandı'];
      let idx = tasks.indexOf(servers[currentDetailIndex].taskStatus);
      servers[currentDetailIndex].taskStatus = tasks[(idx + 1) % tasks.length];

      localStorage.setItem('it_servers', JSON.stringify(servers));
      updateTaskDisplay(servers[currentDetailIndex].taskStatus);
      loadServers();
    }

    function closeDetailModal() {
      document.getElementById('detailModal').classList.add('hidden');
      currentDetailIndex = -1;
    }

    document.addEventListener('DOMContentLoaded', loadServers);
  </script>
</body>

</html>
</body>

</html>
