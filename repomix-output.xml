    (function () {
      const tableBody = document.getElementById("approvalTableBody");
      if (!tableBody) return;

      tableBody.querySelectorAll("tr").forEach((row) => {
        const approveButton = row.querySelector(".approve-btn");
        const rejectButton = row.querySelector(".reject-btn");
        const statusPill = row.querySelector("[data-status]");

        if (approveButton) {
          approveButton.addEventListener("click", () => {
            row.classList.remove("row-rejected");
            row.classList.add("row-approved");
            if (statusPill) {
              statusPill.textContent = "Onaylandi";
              statusPill.className = "status-pill bg-okBg text-okText";
            }
          });
        }

        if (rejectButton) {
          rejectButton.addEventListener("click", () => {
            row.classList.remove("row-approved");
            row.classList.add("row-rejected");
            if (statusPill) {
              statusPill.textContent = "Reddedildi";
              statusPill.className = "status-pill bg-badBg text-badText";
            }
          });
        }
      });
    })();
